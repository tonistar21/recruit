POSTGRES_DB=recruit
POSTGRES_USER=recruit
POSTGRES_PASSWORD=change-this-development-password
RECRUIT_DATABASE_URL=postgresql+psycopg://recruit:change-this-development-password@postgres:5432/recruit
RECRUIT_SECRET_KEY=change-this-to-a-random-secret-of-at-least-32-characters
RECRUIT_ENVIRONMENT=development
RECRUIT_ALLOWED_ORIGINS=["http://localhost:3000"]
RECRUIT_STORAGE_PATH=/app/storage
# GID власника локального каталогу storage/ (команда: id -g)
RECRUIT_STORAGE_GID=1000
RECRUIT_COOKIE_SECURE=false
RECRUIT_SEED_ADMIN_PASSWORD=DemoAdmin123!
